PORT=3001

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Whisper trascrizione vocale)
OPENAI_API_KEY=sk-...

# Microsoft Outlook Calendar Integration
MICROSOFT_CLIENT_ID=xxxxx.apps.microsoftonline.com
MICROSOFT_CLIENT_SECRET=xxxxx
MICROSOFT_TENANT=xxxxx (oppure "common")
MICROSOFT_REDIRECT_URI=https://tuodominio.com/api/outlook/callback

# Frontend URL (per redirect dopo OAuth)
FRONTEND_URL=https://tuodominio.com

# Origini permesse (es. https://tuodominio.com)
ALLOWED_ORIGINS=http://localhost:3001,https://tuodominio.com

# Environment
NODE_ENV=production

